@article{Kim2021,
  title = {What to Expect When It Gets Hotter the Impacts of Prenatal Exposure to Extreme Temperature on Maternal Health},
  author = {Kim, Jiyoon and Lee, A. J.I.N. and {Rossin-Slater}, Maya},
  year = 2021,
  journal = {American Journal of Health Economics},
  volume = {7},
  number = {3},
  pages = {281--305},
  issn = {23323507},
  doi = {10.1086/714359},
  abstract = {We use temperature variation within narrowly defined geographic and demographic cells to show that exposure to extreme temperature increases the risk of maternal hospitalization during pregnancy. This effect is driven by emergency hospitalizations for various pregnancy complications, suggesting that it represents a deterioration in underlying maternal health rather than a change in women's ability to access health care. The effect is larger for black women than for women of other races, suggesting that without significant adaptation, projected increases in extreme temperatures over the next century may further exacerbate racial disparities in maternal health.},
  keywords = {Climate change,Extreme temperature,Health disparity,Hospitalization,Maternal health,Pregnancy}
}

